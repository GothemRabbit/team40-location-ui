        <addForeignKeyConstraint baseColumnNames="profile_details_id"
                                 baseTableName="item"
                                 constraintName="fk_item__profile_details_id"
                                 referencedColumnNames="id"
                                 referencedTableName="profile_details"
                                 />

        <addForeignKeyConstraint baseColumnNames="seller_id"
                                 baseTableName="item"
                                 constraintName="fk_item__seller_id"
                                 referencedColumnNames="id"
                                 referencedTableName="user_details"
                                 />
    </changeSet>
</databaseChangeLog>
